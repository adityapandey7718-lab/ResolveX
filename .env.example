# ResolveX Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Generative AI API Key (from Google AI Studio)
GOOGLE_API_KEY=your_google_api_key_here

# Flask Secret Key (for session encryption)
FLASK_SECRET_KEY=your_random_secret_key_here

# Firebase Admin SDK Configuration
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Firebase Web Client Configuration (for Frontend Authentication)
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
